# Version control
.git/
.gitignore

# Go workspace (only go.work is needed; go.work.sum is not)
go.work.sum

# Build artifacts
.task/
backend/leapmux
*.db
*.db-journal
*.db-wal
*.db-shm

# Generated code (rebuilt in Docker)
generated/
*/generated/
*/*/generated/

# Frontend build artifacts (rebuilt in Docker)
frontend/.output/
frontend/.vinxi/
frontend/node_modules/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Test artifacts
frontend/tests/e2e/test-results/
frontend/tests/e2e/playwright-report/

# Docker files (not needed in build context except rootfs)
docker/Dockerfile

# Desktop app (only go.mod/go.sum needed for workspace-aware go mod download)
desktop/
!desktop/go/go.mod
!desktop/go/go.sum

# Misc
.DS_Store
*.log
mprocs.yaml
