# Centralized tool and image versions. This file is sourced by shell
# scripts, loaded into GitHub Actions via `$GITHUB_ENV`, and exposed to
# Taskfile.yaml via its `dotenv:` directive. Keep entries as plain
# KEY=VALUE lines (UPPER_SNAKE) so every consumer — bash, PowerShell,
# Dockerfile ARGs, Taskfile templates — can read them without a parser.

VERSION=0.0.1-dev

ALPINE_IMAGE=alpine:3.23
UBUNTU_IMAGE=ubuntu:24.04

BUN_VERSION=1.3.13
BUF_VERSION=1.68.3
GOLANG_VERSION=1.26.2
NODE_VERSION=24.15.0
RUST_VERSION=1.95.0
S6_OVERLAY_VERSION=3.2.2.0
TASK_VERSION=3.50.0
