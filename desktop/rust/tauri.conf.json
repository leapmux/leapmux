{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LeapMux Desktop",
  "mainBinaryName": "LeapMux Desktop",
  "version": "0.0.1",
  "identifier": "dev.leapmux.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:4328",
    "frontendDist": "../../frontend/.output/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LeapMux Desktop",
        "width": 900,
        "height": 680,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "resources": [
      "../go/bin/*"
    ],
    "icon": [
      "./icons/icon.png",
      "./icons/icon.ico"
    ]
  }
}
